{
  "version": 3,
  "routes": [
    {
      "src": "/_next/__private/trace",
      "dest": "/404",
      "status": 404,
      "continue": true
    },
    {
      "src": "/404/?",
      "status": 404,
      "continue": true
    },
    {
      "src": "^(?:/((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/]+\\.\\w+))/$",
      "headers": {
        "Location": "/$1"
      },
      "status": 308,
      "missing": [
        {
          "type": "header",
          "key": "x-nextjs-data"
        }
      ]
    },
    {
      "src": "^(?:/((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/\\.]+))$",
      "headers": {
        "Location": "/$1/"
      },
      "status": 308
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/_next/data/(.*)",
      "dest": "/_next/data/$1",
      "check": true
    },
    {
      "src": "/_next/data/(.*)",
      "status": 404
    },
    {
      "handle": "resource"
    },
    {
      "src": "/.*",
      "status": 404
    },
    {
      "handle": "miss"
    },
    {
      "src": "/_next/static/.+",
      "status": 404,
      "check": true,
      "dest": "/_next/static/not-found.txt",
      "headers": {
        "content-type": "text/plain; charset=utf-8"
      }
    },
    {
      "handle": "hit"
    },
    {
      "src": "/_next/static/(?:[^/]+/pages|pages|chunks|runtime|css|image|media|8HjYB9juwuHBzruGxKN6B)/.+",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true,
      "important": true
    },
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": ".*",
      "dest": "/404"
    }
  ],
  "overrides": {
    "404.html": {
      "path": "404",
      "contentType": "text/html; charset=utf-8"
    },
    "_not-found/index.html": {
      "path": "_not-found/index",
      "contentType": "text/html; charset=utf-8"
    },
    "404/index.html": {
      "path": "404/index",
      "contentType": "text/html; charset=utf-8"
    },
    "club-generator/index.html": {
      "path": "club-generator/index",
      "contentType": "text/html; charset=utf-8"
    },
    "club-generator/league/index.html": {
      "path": "club-generator/league/index",
      "contentType": "text/html; charset=utf-8"
    },
    "create/index.html": {
      "path": "create/index",
      "contentType": "text/html; charset=utf-8"
    },
    "eliminated/index.html": {
      "path": "eliminated/index",
      "contentType": "text/html; charset=utf-8"
    },
    "import/index.html": {
      "path": "import/index",
      "contentType": "text/html; charset=utf-8"
    },
    "index.html": {
      "path": "index",
      "contentType": "text/html; charset=utf-8"
    },
    "match-log/index.html": {
      "path": "match-log/index",
      "contentType": "text/html; charset=utf-8"
    },
    "standings/index.html": {
      "path": "standings/index",
      "contentType": "text/html; charset=utf-8"
    },
    "tournament/index.html": {
      "path": "tournament/index",
      "contentType": "text/html; charset=utf-8"
    }
  },
  "framework": {
    "slug": "nextjs",
    "version": "16.2.9"
  },
  "crons": []
}
